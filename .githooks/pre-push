#!/usr/bin/env bash
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "pre-push: working tree has uncommitted changes; commit or stash first." >&2
  exit 1
fi

if upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null); then
  base=$(git merge-base "$upstream" HEAD)
else
  base=$(git rev-list --max-parents=0 HEAD)
fi

mapfile -d '' files < <(git diff --name-only --diff-filter=ACMR -z "$base"...HEAD -- '*.nix')
((${#files[@]} > 0)) && nixfmt "${files[@]}"

if ! git diff --quiet; then
  echo "pre-push: formatted Nix files; commit the changes, then push again." >&2
  exit 1
fi

nix flake check --no-warn-dirty
